# ─────────────────────────────────────────────
# pit-boss — Environment Config
# ─────────────────────────────────────────────
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── AWS / S3 (required) ────────────────────
# Needs read access to the PR-Bouncer S3 bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# The S3 bucket where PR-Bouncer writes reviews and decisions
S3_BUCKET=bm-pr-reviews

# ── Gemini LLM Analysis (optional) ────────
# Enables AI-powered narrative insights, override evaluation,
# and shakedown reasoning. Without this, report is deterministic only.
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Shakedown Integration (optional) ──────
# GitHub PAT with repo scope — used to trigger repo-shakedown via dispatch
# Only needed if you enable auto-triggering in the workflow
# SHAKEDOWN_PAT=ghp_xxxxxxxxxxxx
# SHAKEDOWN_REPO=BeyondMachines/repo-shakedown